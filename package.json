{
  "name": "biscuit-tin-eslint-config",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "author": "Biscuit Tin <opensource@biscuitt.in>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BiscuitTin/eslint-config.git"
  },
  "engines": {
    "node": ">=v24.11.1 <25",
    "bun": ">=999.0.0",
    "npm": ">=999.0.0",
    "yarn": ">=999.0.0"
  },
  "scripts": {
    "build": "pnpm --recursive --filter @biscuittin/* run build",
    "test": "vitest --run --logHeapUsage",
    "coverage": "vitest run --coverage",
    "typegen": "tsx scripts/typegen.ts",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/ni": "^30.2.0",
    "@arethetypeswrong/core": "^0.18.5",
    "@biscuittin/eslint-config": "workspace:^",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/types": "^20.5.0",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "baseline-browser-mapping": "^2.10.43",
    "dprint": "^0.51.1",
    "eslint": "^9.39.5",
    "eslint-typegen": "^2.3.1",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^16.4.0",
    "publint": "^0.3.21",
    "tailwindcss": "^4.3.2",
    "tsdown": "^0.20.3",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
